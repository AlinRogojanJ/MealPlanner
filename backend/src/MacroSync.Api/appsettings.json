{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // "Mock" = in-memory demo data (no DB needed). "Sql" = EF Core against ConnectionStrings:MacroSync.
  "DataSource": "Mock",

  "ConnectionStrings": {
    // Placeholder — replace with your Azure SQL / LocalDB / Docker SQL connection string,
    // then set DataSource to "Sql". Production keeps this in Azure Key Vault.
    "MacroSync": "Server=(localdb)\\MSSQLLocalDB;Database=MacroSync;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Jwt": {
    "Issuer": "MacroSync",
    "Audience": "MacroSync",
    // Dev-only key — production key lives in Azure Key Vault.
    "SigningKey": "dev-only-signing-key-change-me-0123456789abcdef",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },

  "Google": {
    // OAuth client ID for Google Sign-In (one per environment, §5.4). Empty = audience check skipped in dev.
    "ClientId": ""
  }
}
